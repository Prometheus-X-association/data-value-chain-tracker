{
  "name": "blockchain",
  "version": "1.0.0",
  "description": "projects contains smart contracts and tests for the DVCT incentive engine",
  "main": "index.js",
  "directories": {
    "lib": "lib",
    "test": "test"
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "ptx-deploy": "hardhat ignition deploy ./ignition/modules/PTXProtocol.ts --network localhost",
    "ptx-deploy-test": "hardhat run script/deployTestEnv.ts --network localhost",
    "ptx-fund-wallet": "hardhat run script/fundWallet.ts --network localhost",
    "export-abis": "hardhat compile && ts-node script/exportAbis.ts",
    "export-abis-to-api": "hardhat compile && ts-node script/exportAbisToApi.ts",
    "node": "hardhat node",
    "docs": "forge doc",
    "clean": "hardhat clean",
    "copy-types": "hardhat compile && cp -R ./typechain-types ../api/src/typechain-types"
  },
